+ 
+     /* Remaining 16-element chunks */
+     for (; i + step16 <= d; i += step16) {
+         svfloat16_t xv = svld1_f16(pg16, x + i);
+         svfloat16_t y0v = svld1_f16(pg16, y0 + i);
