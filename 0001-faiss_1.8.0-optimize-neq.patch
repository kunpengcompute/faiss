+    }
+    if (ny & 2) {
+        krl_L2sqr_batch2_u8f32(x, y + i * d, d, dis + i);
+        i += 2;
+    }
+    if (ny & 1) {
+        uint32_t tmp;
+        krl_L2sqr_u8u32(x, y + i * d, d, &tmp);
+        dis[i] = (float)tmp;
+    }
