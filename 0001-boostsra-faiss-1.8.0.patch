+            for(int i = 0; i < ncode; ++i) {
+                distance[i] = dis0 + distance_single_code_generic<TA,TR>(d, lut, codes + idx[i] * d);
+            }
+            clock_gettime(CLOCK_MONOTONIC, &endTime);
+        } else {
