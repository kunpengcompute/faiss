+    if (ny & 2) {
+        krl_L2sqr_batch2_f16f32((const float16_t *)x, (const float16_t *)y + i * d, d, dis + i);
+        i += 2;
+    }
+    if (ny & 1) {
+        krl_L2sqr_f16f32(x, y + i * d, d, &dis[i], 1);
+    }
+    return SUCCESS;
+}
