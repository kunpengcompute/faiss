+/*
+test API list:
+1. krl_L2_table_lookup_fast_scan_bs64
+2. krl_IP_table_lookup_fast_scan_bs64
+3. krl_L2_table_lookup_fast_scan_bs96
+4. krl_IP_table_lookup_fast_scan_bs96
+5. krl_pack_codes_4b
+6. krl_table_lookup_4b_f16
