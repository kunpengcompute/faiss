+        index_l2_fp16 = new faiss::IndexHNSW2Level(quantizer, nlist, m_pq, M);
+        index_l2_fp32 = new faiss::IndexHNSW2Level(quantizer, nlist, m_pq, M);
+
+        // 设置HNSW参数
+        index_l2_fp16->hnsw.efConstruction = 200;
+        index_l2_fp32->hnsw.efConstruction = 200;
+
+        // 训练索引
+        index_l2_fp16->train_ex(nb, xb_fp16.data(), ntype);
+        index_l2_fp32->train(nb, xb_fp32.data());
+
+        // 添加数据
+        index_l2_fp16->add_ex(nb, xb_fp16.data(), ntype);
+        index_l2_fp32->add(nb, xb_fp32.data());
