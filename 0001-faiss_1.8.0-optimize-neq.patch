+        krl_L2sqr_idx_batch2_u8f32(x, y0, y1, d, dis + i);
+        i += 2;
+    }
+    if (ny & 1) {
+        uint32_t tmp;
+        krl_L2sqr_u8u32(x, y + d * ids[i], d, &tmp);
+        dis[i] = (float)tmp;
+    }
+    return SUCCESS;
