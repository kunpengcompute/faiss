+        /* Accumulate results */
+        neon_res1 = vpaddq_f16(neon_res1, neon_res2);
+        neon_res3 = vpaddq_f16(neon_res3, neon_res4);
+        neon_res1 = vpaddq_f16(neon_res1, neon_res3);
+        neon_res1 = vpaddq_f16(neon_res1, neon_res1);
