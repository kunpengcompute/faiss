+            d2 += x[i] * *(y[2] + i);
+            d3 += x[i] * *(y[3] + i);
+        }
+        dis[0] += d0;
+        dis[1] += d1;
+        dis[2] += d2;
+        dis[3] += d3;
+    }
+}
+KRL_IMPRECISE_FUNCTION_END
