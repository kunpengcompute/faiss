+#include "common_test_functions.h"
+
+class TestIndexHNSWSQ : public ::testing::Test {
+protected:
+    void SetUp() override
+    {
+        d = 128;
+        nb = 20000;
+        nq = 20;
+        k = 10;
+        M = 64;
+        efc = 500;
+        efs = 200;
