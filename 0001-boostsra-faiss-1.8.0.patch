diff -Naur '--exclude=.*' faiss/faiss/sra_krl/src/Heap_sort.c boostsra-faiss/faiss/sra_krl/src/Heap_sort.c
--- faiss/faiss/sra_krl/src/Heap_sort.c	1970-01-01 08:00:00.000000000 +0800
+++ boostsra-faiss/faiss/sra_krl/src/Heap_sort.c	2025-11-13 16:22:58.460674100 +0800
@@ -0,0 +1,437 @@
+/*
