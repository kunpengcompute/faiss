--- faiss/faiss/sra_krl/src/handle_IO.c	1970-01-01 08:00:00.000000000 +0800
+++ boostsra-faiss/faiss/sra_krl/src/handle_IO.c	2025-11-13 16:22:58.469674600 +0800
@@ -0,0 +1,280 @@
+/*
