+        const uint8x16_t d8_1 = vabdq_u8(x8_1, y8_1);
+        const uint8x16_t d8_2 = vabdq_u8(x8_2, y8_2);
+        const uint8x16_t d8_3 = vabdq_u8(x8_3, y8_3);
