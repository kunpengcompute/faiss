+        i = 0;
+    }
+
+    /* Handle remaining elements */
+    if (i < d) {
+        float16_t d0 = x[i] * *(y + i);
+        float16_t d1 = x[i] * *(y + d + i);
+        float16_t d2 = x[i] * *(y + 2 * d + i);
+        float16_t d3 = x[i] * *(y + 3 * d + i);
