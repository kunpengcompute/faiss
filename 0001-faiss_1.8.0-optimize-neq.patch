+        res4 = vdotq_s32(res4, x8_1, y8_3);
+    }
+
+    /* Process remaining vectors in batches of 16 */
+    for (; i + single_round <= d; i += single_round) {
+        const int8x16_t x8_0 = vld1q_s8(x + i);
