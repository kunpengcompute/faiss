+        float32x4_t d8_1 = vsubq_f32(x8_1, y8_1);
+        d8_1 = vmulq_f32(d8_1, d8_1);
+        float32x4_t d8_2 = vsubq_f32(x8_2, y8_2);
+        d8_2 = vmulq_f32(d8_2, d8_2);
+        float32x4_t d8_3 = vsubq_f32(x8_3, y8_3);
+        d8_3 = vmulq_f32(d8_3, d8_3);
