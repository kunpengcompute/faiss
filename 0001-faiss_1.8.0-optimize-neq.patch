+        float32x4_t y8_0 = vld1q_f32(y);
+        float32x4_t y8_1 = vld1q_f32(y + 4);
+        float32x4_t y8_2 = vld1q_f32(y + 8);
+        float32x4_t y8_3 = vld1q_f32(y + 12);
