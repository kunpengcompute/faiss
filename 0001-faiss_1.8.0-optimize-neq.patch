+        float16x8_t neon_res2 = vmulq_f16(neon_base2, neon_query);
+        float16x8_t neon_res3 = vmulq_f16(neon_base3, neon_query);
+        float16x8_t neon_res4 = vmulq_f16(neon_base4, neon_query);
