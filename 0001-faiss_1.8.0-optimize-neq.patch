+
+  local cflags="${COV_CFLAGS} ${omp_flag}"
+  local ldflags="${omp_flag} -Wl,-rpath,${omp_dir}"
+
+  CC="${CLANG_C}" CXX="${CLANG_CXX}" cmake -S "${ROOT_DIR}" -B "${BUILD_CLANG}" \
+    -DCMAKE_TOOLCHAIN_FILE="${TOOLCHAIN_SMART}" \
+    "${COMMON_CMAKE_OPTS[@]}" \
