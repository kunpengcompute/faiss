+            (const uint16_t*)f16_x, d, ny, nx, nloops, krl_inner_product_ny_f16f16); print_result_table(verbose,
+            "krl_inner_product_by_idx_f16f16", simd_time, IP_fops, nx * ny, simd_test, gt, 4e-3);
+        }
+
+        delete[] simd_test;
