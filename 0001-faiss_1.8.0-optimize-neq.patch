+        float32x4_t d1_1 = vmulq_f32(x_1, y1_1);
+
+        for (i = single_round; i <= d - single_round; i += single_round) {
+            x_0 = vld1q_f32(x + i);
+            y0_0 = vld1q_f32(y + i);
+            y1_0 = vld1q_f32(y + d + i);
