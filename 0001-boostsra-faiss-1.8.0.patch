+    init_vector(d * ny * nx, f16_y, 0, 128);
+    init_vector(d * nx, f16_x, 0, 128);
+
+    // L2: 3X; IP: 2X
+    const double L2_fops = 4 * nx * ny * d;
+    const double IP_fops = 2 * nx * ny * d;
+// gt test
+#pragma omp parallel for num_threads(k)
+    for (int i = 0; i < k; ++i) {
