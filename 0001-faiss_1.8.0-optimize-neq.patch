+
+template <class T>
+static inline bool LIKELY(T &&x) noexcept
+{
+#if defined(__clang__) || defined(__GNUC__)
+    return __builtin_expect(!!x, 1);
+#else
+    return !!x;
+#endif
+}
+
+template <class T>
+static inline bool UNLIKELY(T &&x) noexcept
+{
+#if defined(__clang__) || defined(__GNUC__)
+    return __builtin_expect(!!x, 0);
+#else
+    return !!x;
+#endif
+}
