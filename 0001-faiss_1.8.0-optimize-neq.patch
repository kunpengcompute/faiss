+            prefetch_Lx(x + i + multi_round);
+            prefetch_Lx(y + i + multi_round);
+            x8_0 = vld1q_f32(x + i);
+            y8_0 = vld1q_f32(y + i);
+            const float32x4_t q8_0 = vsubq_f32(x8_0, y8_0);
+            d8_0 = vmlaq_f32(d8_0, q8_0, q8_0);
