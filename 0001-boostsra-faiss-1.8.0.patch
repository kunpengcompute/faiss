+{
+    std::vector<size_t> v_dim = {8, 5, 16, 49, 30, 127, 0, 1, 2, 2, 8, 6, 127, 0, 4, 2, 4, 14, 12, 127, 0};
+    std::vector<size_t> v_nx = {12, 20, 8, 16, 32, 15, 0, 96, 50, 64, 98, 160, 15, 0, 24, 50, 32, 56, 80, 15, 0};
