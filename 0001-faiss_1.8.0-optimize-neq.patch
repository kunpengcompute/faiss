+void IndexHNSW::search_level_0(
+        idx_t n,
+        const float16_t* x,
+        idx_t k,
+        const storage_idx_t* nearest,
+        const float* nearest_d,
+        float* distances,
+        idx_t* labels,
+        int nprobe,
+        int search_type) const {
