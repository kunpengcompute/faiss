diff -Naur '--exclude=.git' '--exclude=.vscode' faiss/faiss/sra_krl/src/pq_search_with_table_4bit.c faiss-patch/faiss/sra_krl/src/pq_search_with_table_4bit.c
--- faiss/faiss/sra_krl/src/pq_search_with_table_4bit.c	1970-01-01 08:00:00.000000000 +0800
+++ faiss-patch/faiss/sra_krl/src/pq_search_with_table_4bit.c	2026-06-10 15:51:41.058391600 +0800
@@ -0,0 +1,1302 @@
+/*
+   Copyright 2025 Huawei Technologies Co., Ltd.
+
+   Licensed under the Apache License, Version 2.0 (the "License");
+   you may not use this file except in compliance with the License.
+   You may obtain a copy of the License at
