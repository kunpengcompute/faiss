+        float d6 = x[i] * *(y[6] + i);
+        float d7 = x[i] * *(y[7] + i);
+        float d8 = x[i] * *(y[8] + i);
+        float d9 = x[i] * *(y[9] + i);
+        float d10 = x[i] * *(y[10] + i);
+        float d11 = x[i] * *(y[11] + i);
+        float d12 = x[i] * *(y[12] + i);
+        float d13 = x[i] * *(y[13] + i);
+        float d14 = x[i] * *(y[14] + i);
+        float d15 = x[i] * *(y[15] + i);
+        for (i++; i < d; ++i) {
+            d0 += x[i] * *(y[0] + i);
+            d1 += x[i] * *(y[1] + i);
+            d2 += x[i] * *(y[2] + i);
+            d3 += x[i] * *(y[3] + i);
+            d4 += x[i] * *(y[4] + i);
+            d5 += x[i] * *(y[5] + i);
+            d6 += x[i] * *(y[6] + i);
+            d7 += x[i] * *(y[7] + i);
+            d8 += x[i] * *(y[8] + i);
+            d9 += x[i] * *(y[9] + i);
+            d10 += x[i] * *(y[10] + i);
+            d11 += x[i] * *(y[11] + i);
+            d12 += x[i] * *(y[12] + i);
+            d13 += x[i] * *(y[13] + i);
+            d14 += x[i] * *(y[14] + i);
+            d15 += x[i] * *(y[15] + i);
+        }
+        dis[0] += d0;
+        dis[1] += d1;
+        dis[2] += d2;
+        dis[3] += d3;
+        dis[4] += d4;
+        dis[5] += d5;
+        dis[6] += d6;
+        dis[7] += d7;
