+        neon_query6 = veorq_u8(neon_query6, neon_base);
+        neon_query7 = veorq_u8(neon_query7, neon_base);
+        neon_query0 = vcntq_u8(neon_query0);
+        neon_query1 = vcntq_u8(neon_query1);
