+// ============================================================
+// DistanceCodesN8x1S
+//   AAPCS64: x0=M, x1=sim_table, x2=code, s0=dis, return s0
+// ============================================================
+.global DistanceCodesN8x1S
+.type   DistanceCodesN8x1S, %function
+DistanceCodesN8x1S:
+    // acc in s16
+    fmov    s16, s0
+
+    mov     x6, x0
+    cbz     x6, .L1_ret
+
+    cmp     x6, #4
+    b.lt    .L1_tail_ge2
+
+.L1_loop_main:
+    prfm    pldl1keep, [x1, #8192]
+
+    ldr     w12, [x2], #4
+
+    mov     x8, x1
+    add     x9, x1, #0x400
+    add     x5, x1, #0x800
+    add     x3, x1, #0xC00
+
+    // row0 byte0
+    and     w4, w12, #0xff
+    ldr     s0, [x8, x4, lsl #2]
+    fadd    s16, s16, s0
+
+    // row1 byte1
+    ubfx    w4, w12, #8, #8
+    ldr     s0, [x9, x4, lsl #2]
+    fadd    s16, s16, s0
+
+    // row2 byte2
+    ubfx    w4, w12, #16, #8
+    ldr     s0, [x5, x4, lsl #2]
+    fadd    s16, s16, s0
+
+    // row3 byte3
+    lsr     w12, w12, #24
+    ldr     s0, [x3, x12, lsl #2]
+    fadd    s16, s16, s0
+
+    add     x1, x1, #0x1000
+    subs    x6, x6, #4
+    cmp     x6, #4
+    b.ge    .L1_loop_main
+
+.L1_tail_ge2:
+    cmp     x6, #2
+    b.lt    .L1_tail_ge1
+
+    prfm    pldl1keep, [x1, #8192]
+
+    ldrh    w12, [x2], #2
+
+    mov     x8, x1
+    add     x9, x1, #0x400
+
+    // row0 byte0
+    and     w4, w12, #0xff
+    ldr     s0, [x8, x4, lsl #2]
+    fadd    s16, s16, s0
+
+    // row1 byte1
+    lsr     w12, w12, #8
+    and     w4, w12, #0xff
+    ldr     s0, [x9, x4, lsl #2]
+    fadd    s16, s16, s0
+
+    add     x1, x1, #0x800
+    subs    x6, x6, #2
+
+.L1_tail_ge1:
+    cbz     x6, .L1_ret
+
+    ldrb    w12, [x2]
+    ldr     s0, [x1, x12, lsl #2]
+    fadd    s16, s16, s0
+
+.L1_ret:
+    fmov    s0, s16
+    ret
+.size DistanceCodesN8x1S, .-DistanceCodesN8x1S
