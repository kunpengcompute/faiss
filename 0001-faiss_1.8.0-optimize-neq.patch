+        krl_inner_product_ny_f16f32(base_dis, (const uint16_t *)query_vector, (const uint16_t *)base_vector + begin_id * d, base_k, d);
+        krl_reorder_2_heaps_desc(k, idx, dis, base_k, base_idx, base_dis);
