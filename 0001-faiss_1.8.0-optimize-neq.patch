+            result[2] = vpadalq_u8(result[2], mask1_1);
+            result[3] = vpadalq_u8(result[3], mask1_2);
+        }
+    }
+
+    if constexpr (keep_min == 0) {
+        const uint16x8_t threshold_simd = vdupq_n_u16(threshold);
+        constexpr uint16x8_t offset = FILTER_OFFSET;
