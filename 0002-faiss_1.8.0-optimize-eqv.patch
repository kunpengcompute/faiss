+        listy[22] = (const float16_t *)(y + *(ids + i + 22) * d);
+        prefetch_Lx(listy[22]); /* Prefetch y vector 22 into Lx cache */
+        listy[23] = (const float16_t *)(y + *(ids + i + 23) * d);
+        prefetch_Lx(listy[23]); /* Prefetch y vector 23 into Lx cache */
