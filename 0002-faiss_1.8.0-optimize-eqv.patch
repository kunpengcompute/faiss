+    /* Handle remaining vectors */
+    if (i + 16 <= ny) {
+        /* Load 16 vectors from y based on ids */
+        listy[0] = (const int8_t *)(y + *(ids + i) * d);
+        listy[1] = (const int8_t *)(y + *(ids + i + 1) * d);
