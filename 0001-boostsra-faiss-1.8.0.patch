+template<typename TA, typename TR>
+inline TR distance_single_code_generic(
+        const size_t M,
+        const TA* sim_table,
+        const uint8_t* code) {
+    constexpr size_t ksub = 256;
+
+    const TA* tab = sim_table;
+    TR result = 0;
+
+    for (size_t m = 0; m < M; m++) {
+        result += tab[*code];
+        code++;
+        tab += ksub;
+    }
+
+    return result;
+}
