+// ============================================================
+// DistanceCodesN8x2S
+//   2 codes packed as [code0(M)][code1(M)]
+//   AAPCS64: x0=M, x1=sim_table, x2=codes, x3=result, s0=dis
+// ============================================================
+.global DistanceCodesN8x2S
+.type   DistanceCodesN8x2S, %function
+DistanceCodesN8x2S:
+    dup     v16.2s, v0.s[0]
+
+    // c0, c1
+    mov     x10, x2
+    add     x11, x2, x0
+
+    mov     x6, x0
+    cbz     x6, .L2_store
+
+    cmp     x6, #4
+    b.lt    .L2_tail_ge2
+
+.L2_loop_main:
+    prfm    pldl1keep, [x1, #8192]
+
+    ldr     w12, [x10], #4
+    ldr     w13, [x11], #4
+
+    mov     x8, x1
+    add     x9, x1, #0x400
+    add     x5, x1, #0x800
+    add     x2, x1, #0xC00
+
+    // row0 byte0
+    and     w4, w12, #0xff
+    ldr     s0, [x8, x4, lsl #2]
+    and     w4, w13, #0xff
+    ldr     s1, [x8, x4, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+    // row1 byte1
+    ubfx    w4, w12, #8, #8
+    ldr     s0, [x9, x4, lsl #2]
+    ubfx    w4, w13, #8, #8
+    ldr     s1, [x9, x4, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+    // row2 byte2
+    ubfx    w4, w12, #16, #8
+    ldr     s0, [x5, x4, lsl #2]
+    ubfx    w4, w13, #16, #8
+    ldr     s1, [x5, x4, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+    // row3 byte3
+    lsr     w12, w12, #24
+    lsr     w13, w13, #24
+    ldr     s0, [x2, x12, lsl #2]
+    ldr     s1, [x2, x13, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+    add     x1, x1, #0x1000
+    subs    x6, x6, #4
+    cmp     x6, #4
+    b.ge    .L2_loop_main
+
+.L2_tail_ge2:
+    cmp     x6, #2
+    b.lt    .L2_tail_ge1
+
+    prfm    pldl1keep, [x1, #8192]
+
+    ldrh    w12, [x10], #2
+    ldrh    w13, [x11], #2
+
+    mov     x8, x1
+    add     x9, x1, #0x400
+
+    // row0 byte0
+    and     w4, w12, #0xff
+    ldr     s0, [x8, x4, lsl #2]
+    and     w4, w13, #0xff
+    ldr     s1, [x8, x4, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+    // row1 byte1
+    lsr     w12, w12, #8
+    lsr     w13, w13, #8
+    and     w4, w12, #0xff
+    ldr     s0, [x9, x4, lsl #2]
+    and     w4, w13, #0xff
+    ldr     s1, [x9, x4, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+    add     x1, x1, #0x800
+    subs    x6, x6, #2
+
+.L2_tail_ge1:
+    cbz     x6, .L2_store
+
+    ldrb    w12, [x10]
+    ldrb    w13, [x11]
+
+    mov     x8, x1
+    ldr     s0, [x8, x12, lsl #2]
+    ldr     s1, [x8, x13, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+.L2_store:
+    str     d16, [x3]
+    ret
+.size DistanceCodesN8x2S, .-DistanceCodesN8x2S
