+        float16x8_t neon_base1 = vld1q_f16(y);
+        float16x8_t neon_base2 = vld1q_f16(y + d);
+        float16x8_t neon_base3 = vld1q_f16(y + 2 * d);
+        float16x8_t neon_base4 = vld1q_f16(y + 3 * d);
