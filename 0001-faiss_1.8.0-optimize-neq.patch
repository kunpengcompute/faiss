+ * @param ny Number of vectors to process.
+ * @param d Dimension of the vectors.
+ */
+int krl_L2sqr_ny_u8f32(float *dis, const uint8_t *x, const uint8_t *y, size_t ny, size_t d)
+{
+    size_t i = 0;
+
+    for (; i + 16 <= ny; i += 16) {
+        krl_L2sqr_batch16_u8f32(x, y + i * d, d, dis + i);
+    }
+    if (ny & 8) {
+        krl_L2sqr_batch8_u8f32(x, y + i * d, d, dis + i);
+        i += 8;
+    }
+    if (ny & 4) {
+        krl_L2sqr_batch4_u8f32(x, y + i * d, d, dis + i);
+        i += 4;
+    }
+    if (ny & 2) {
+        krl_L2sqr_batch2_u8f32(x, y + i * d, d, dis + i);
+        i += 2;
+    }
+    if (ny & 1) {
+        uint32_t tmp;
+        krl_L2sqr_u8u32(x, y + i * d, d, &tmp);
+        dis[i] = (float)tmp;
+    }
