+              << " passed (" << consistency_rate * 100 << "%)" << std::endl;
+
+    EXPECT_GE(consistency_rate, 0.90) << "FP16-FP32 KNN by ID consistency rate too low: " << consistency_rate * 100
+                                      << "%";
+}
+
+TEST_F(TestDistances, range_search_L2sqr_f16)
