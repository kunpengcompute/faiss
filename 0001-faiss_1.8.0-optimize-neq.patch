+        uint8x16_t neon_base   = vld1q_u8(base + i * 16); // += 16
+        uint8x16_t neon_query0 = vld1q_u8(query + i * 16); // += 64
+        uint8x16_t neon_query1 = vld1q_u8(query + i * 16 + dim);
+        uint8x16_t neon_query2 = vld1q_u8(query + i * 16 + dim * 2);
