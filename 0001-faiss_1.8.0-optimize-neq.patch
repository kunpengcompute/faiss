+            d14 += x[i] * *(y[14] + i);
+            d15 += x[i] * *(y[15] + i);
+        }
+        dis[0] += d0;
+        dis[1] += d1;
+        dis[2] += d2;
+        dis[3] += d3;
+        dis[4] += d4;
+        dis[5] += d5;
+        dis[6] += d6;
+        dis[7] += d7;
+        dis[8] += d8;
+        dis[9] += d9;
+        dis[10] += d10;
+        dis[11] += d11;
+        dis[12] += d12;
+        dis[13] += d13;
+        dis[14] += d14;
+        dis[15] += d15;
+    }
+}
+KRL_IMPRECISE_FUNCTION_END
