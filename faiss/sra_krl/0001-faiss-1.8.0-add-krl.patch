+    constexpr idx_t single_loop = 8;
+    for(; l + multi_loop <= d; l += multi_loop) {
+        float32x4_t neon_a1 = vld1q_f32(src + l);
+        float32x4_t neon_a2 = vld1q_f32(src + l + 4);
+        float32x4_t neon_a3 = vld1q_f32(src + l + 8);
