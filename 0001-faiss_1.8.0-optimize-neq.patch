+    } else {
+        for (int i = 0; i < 16; i++) {
+            dis[i] = 0.0f;
+        }
+        i = 0;
+    }
+    if (i < d) {
+        float d0 = x[i] * *(y[0] + i);
+        float d1 = x[i] * *(y[1] + i);
+        float d2 = x[i] * *(y[2] + i);
+        float d3 = x[i] * *(y[3] + i);
+        float d4 = x[i] * *(y[4] + i);
+        float d5 = x[i] * *(y[5] + i);
+        float d6 = x[i] * *(y[6] + i);
+        float d7 = x[i] * *(y[7] + i);
+        float d8 = x[i] * *(y[8] + i);
+        float d9 = x[i] * *(y[9] + i);
+        float d10 = x[i] * *(y[10] + i);
+        float d11 = x[i] * *(y[11] + i);
+        float d12 = x[i] * *(y[12] + i);
+        float d13 = x[i] * *(y[13] + i);
+        float d14 = x[i] * *(y[14] + i);
+        float d15 = x[i] * *(y[15] + i);
+        for (i++; i < d; ++i) {
+            d0 += x[i] * *(y[0] + i);
+            d1 += x[i] * *(y[1] + i);
+            d2 += x[i] * *(y[2] + i);
+            d3 += x[i] * *(y[3] + i);
+            d4 += x[i] * *(y[4] + i);
+            d5 += x[i] * *(y[5] + i);
