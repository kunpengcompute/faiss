+        float16x8_t neon_query = vld1q_f16(x + i);
+        float16x8_t neon_base1 = vld1q_f16(y[0] + i);
+        float16x8_t neon_base2 = vld1q_f16(y[1] + i);
+        float16x8_t neon_base3 = vld1q_f16(y[2] + i);
