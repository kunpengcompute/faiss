+            float16_t q1 = x[i] - *(y[1] + i);
+            float16_t q2 = x[i] - *(y[2] + i);
+            float16_t q3 = x[i] - *(y[3] + i);
+            d0 += q0 * q0;
+            d1 += q1 * q1;
+            d2 += q2 * q2;
+            d3 += q3 * q3;
