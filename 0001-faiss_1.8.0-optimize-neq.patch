+        ldr  w7,  [x24], #2
+        add  x4,  x1,  #0x400
+        ldr  w10, [x2],  #2
+        add  x5,  x5,  #0x2
+        ldr  w8,  [x25], #2
+        and  x12, x7,  #0xff
+        ldr  w6,  [x23], #2
+        and  x14, x10, #0xff
+        and  x13, x8,  #0xff
+        ldr  w9,  [x22], #2
+        and  x11, x6,  #0xff
+        ldr  s0,  [x1, x12, lsl #2]
+        ubfx x12, x8,  #8, #8
+        ldr  w8,  [x21], #2
+        ldr  s5,  [x1, x13, lsl #2]
+        and  x15, x9,  #0xff
+        ldr  s4,  [x1, x11, lsl #2]
+        ubfx x13, x10, #8, #8
+        ldr  s2,  [x1, x14, lsl #2]
+        ubfx x10, x6,  #8, #8
+        ubfx x11, x7,  #8, #8
+        and  x14, x8,  #0xff
+        ldr  w7,  [x20], #2
+        ubfx x9,  x9,  #8, #8
+        mov  v2.s[1], v5.s[0]
+        ldr  w6,  [x26], #2
+        mov  v0.s[1], v4.s[0]
+        ldr  s17, [x1, x15, lsl #2]
+        ldr  s16, [x4, x12, lsl #2]
+        ubfx x8,  x8,  #8, #8
+        ldr  s7,  [x1, x14, lsl #2]
+        and  x12, x7,  #0xff
+        ldr  s6,  [x4, x10, lsl #2]
+        and  x10, x6,  #0xff
+        ldr  s5,  [x4, x13, lsl #2]
+        ubfx x7,  x7,  #8, #8
+        ldr  s4,  [x4, x11, lsl #2]
+        ubfx x6,  x6,  #8, #8
+        mov  v2.s[2], v17.s[0]
+        ldr  s17, [x1, x12, lsl #2]
+        mov  v5.s[1], v16.s[0]
+        ldr  s16, [x4, x9,  lsl #2]
+        mov  v0.s[2], v7.s[0]
+        ldr  s7,  [x1, x10, lsl #2]
+        mov  v4.s[1], v6.s[0]
+        ldr  s6,  [x4, x8,  lsl #2]
+        mov  v2.s[3], v17.s[0]
+        prfm pldl1keep, [x1, #8192]
+        mov  v5.s[2], v16.s[0]
+        add  x1,  x1,  #0x800
+        mov  v0.s[3], v7.s[0]
+        ldr  s7,  [x4, x7,  lsl #2]
+        mov  v4.s[2], v6.s[0]
+        ldr  s6,  [x4, x6,  lsl #2]
+        fadd v2.4s, v2.4s, v3.4s
+        mov  v5.s[3], v7.s[0]
+        fadd v0.4s, v0.4s, v1.4s
+        mov  v4.s[3], v6.s[0]
+        fadd v3.4s, v5.4s, v2.4s
+        fadd v1.4s, v1.4s, v0.4s
+
+.Ltail_lt_full:
+        cmp  x5, x0
+        b.cs .Lstore_out
+
+        // final 1-byte tail
+        ldrb w5, [x2]
+        ldrb w4, [x25]
+        ldrb w2, [x24]
+        ldrb w0, [x23]
+        ldr  s2, [x1, x5, lsl #2]
+        ldr  s5, [x1, x4, lsl #2]
+        ldr  s0, [x1, x2, lsl #2]
+        ldr  s4, [x1, x0, lsl #2]
+        ldrb w5, [x22]
+        mov  v2.s[1], v5.s[0]
+        ldrb w4, [x21]
+        mov  v0.s[1], v4.s[0]
+        ldrb w2, [x20]
+        ldrb w0, [x26]
+        ldr  s4, [x1, x5, lsl #2]
+        ldr  s6, [x1, x4, lsl #2]
+        ldr  s5, [x1, x2, lsl #2]
+        mov  v2.s[2], v4.s[0]
+        ldr  s4, [x1, x0, lsl #2]
+        mov  v0.s[2], v6.s[0]
+        mov  v2.s[3], v5.s[0]
+        mov  v0.s[3], v4.s[0]
+        fadd v3.4s, v3.4s, v2.4s
+        fadd v1.4s, v1.4s, v0.4s
+
+.Lstore_out:
+        // store 8 results: [q3 q1]
+        stp  q3, q1, [x3]
+        ldp  x19, x20, [sp, #16]
+        ldp  x21, x22, [sp, #32]
+        ldp  x23, x24, [sp, #48]
+        ldp  x25, x26, [sp, #64]
+        ldp  x29, x30, [sp], #112
+        ret
+
+.Lsmall_M:
+        // fall back to tail handler with small M
+        mov  v1.16b, v3.16b
+        mov  x7, #0x1
+        mov  x5, #0x0
+        b    .Ltail_ge4
+.size DistanceCodesN8x8S, .-DistanceCodesN8x8S
+
+
+// ============================================================
+// DistanceCodesN8x4S
+//   4 codes packed as [code0(M)][code1(M)][code2(M)][code3(M)]
+//   AAPCS64: x0=M, x1=sim_table, x2=codes, x3=result, s0=dis
+// ============================================================
+.global DistanceCodesN8x4S
+.type   DistanceCodesN8x4S, %function
+DistanceCodesN8x4S:
+    // acc = [dis, dis, dis, dis]
+    dup     v16.4s, v0.s[0]
+
+    // c0..c3
+    mov     x10, x2
+    add     x11, x2, x0
+    add     x12, x11, x0
+    add     x13, x12, x0
+
+    mov     x6, x0
+    cbz     x6, .L4_store
+
+    cmp     x6, #4
+    b.lt    .L4_tail_ge2
+
+.L4_loop_main:
+    prfm    pldl1keep, [x1, #8192]
+
+    // read 4 bytes from each code stream
+    ldr     w14, [x10], #4
+    ldr     w15, [x11], #4
+    ldr     w16, [x12], #4
+    ldr     w17, [x13], #4
+
+    // row bases
+    mov     x8, x1
+    add     x9, x1, #0x400
+    add     x5, x1, #0x800
+    add     x2, x1, #0xC00
+
+    // row0 (byte0) -> v0
+    and     w4, w14, #0xff
+    ldr     s0, [x8, x4, lsl #2]
+    and     w4, w15, #0xff
+    ldr     s1, [x8, x4, lsl #2]
+    and     w4, w16, #0xff
+    ldr     s2, [x8, x4, lsl #2]
+    and     w4, w17, #0xff
+    ldr     s3, [x8, x4, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    mov     v0.s[2], v2.s[0]
+    mov     v0.s[3], v3.s[0]
+
+    // row1 (byte1) -> v4
+    ubfx    w4, w14, #8, #8
+    ldr     s4, [x9, x4, lsl #2]
+    ubfx    w4, w15, #8, #8
+    ldr     s5, [x9, x4, lsl #2]
+    ubfx    w4, w16, #8, #8
+    ldr     s6, [x9, x4, lsl #2]
+    ubfx    w4, w17, #8, #8
+    ldr     s7, [x9, x4, lsl #2]
+    mov     v4.s[1], v5.s[0]
+    mov     v4.s[2], v6.s[0]
+    mov     v4.s[3], v7.s[0]
+    fadd    v0.4s, v0.4s, v4.4s
+
+    // row2 (byte2) -> v4
+    ubfx    w4, w14, #16, #8
+    ldr     s4, [x5, x4, lsl #2]
+    ubfx    w4, w15, #16, #8
+    ldr     s5, [x5, x4, lsl #2]
+    ubfx    w4, w16, #16, #8
+    ldr     s6, [x5, x4, lsl #2]
+    ubfx    w4, w17, #16, #8
+    ldr     s7, [x5, x4, lsl #2]
+    mov     v4.s[1], v5.s[0]
+    mov     v4.s[2], v6.s[0]
+    mov     v4.s[3], v7.s[0]
+
+    // row3 (byte3) -> v5
+    lsr     w14, w14, #24
+    lsr     w15, w15, #24
+    lsr     w16, w16, #24
+    lsr     w17, w17, #24
+    ldr     s5, [x2, x14, lsl #2]
+    ldr     s1, [x2, x15, lsl #2]
+    ldr     s2, [x2, x16, lsl #2]
+    ldr     s3, [x2, x17, lsl #2]
+    mov     v5.s[1], v1.s[0]
+    mov     v5.s[2], v2.s[0]
+    mov     v5.s[3], v3.s[0]
+
+    // v0 += row2 + row3; acc += v0
+    fadd    v4.4s, v4.4s, v5.4s
+    fadd    v0.4s, v0.4s, v4.4s
+    fadd    v16.4s, v16.4s, v0.4s
+
+    // tab += 4 rows
+    add     x1, x1, #0x1000
+    subs    x6, x6, #4
+    cmp     x6, #4
+    b.ge    .L4_loop_main
+
+.L4_tail_ge2:
+    cmp     x6, #2
+    b.lt    .L4_tail_ge1
+
+    prfm    pldl1keep, [x1, #8192]
+
+    // read 2 bytes per code
+    ldrh    w14, [x10], #2
+    ldrh    w15, [x11], #2
+    ldrh    w16, [x12], #2
+    ldrh    w17, [x13], #2
+
+    mov     x8, x1
+    add     x9, x1, #0x400
+
+    // row0 (byte0)
+    and     w4, w14, #0xff
+    ldr     s0, [x8, x4, lsl #2]
+    and     w4, w15, #0xff
+    ldr     s1, [x8, x4, lsl #2]
+    and     w4, w16, #0xff
+    ldr     s2, [x8, x4, lsl #2]
+    and     w4, w17, #0xff
+    ldr     s3, [x8, x4, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    mov     v0.s[2], v2.s[0]
+    mov     v0.s[3], v3.s[0]
+
+    // row1 (byte1)
+    lsr     w14, w14, #8
+    lsr     w15, w15, #8
+    lsr     w16, w16, #8
+    lsr     w17, w17, #8
+    and     w4, w14, #0xff
+    ldr     s4, [x9, x4, lsl #2]
+    and     w4, w15, #0xff
+    ldr     s5, [x9, x4, lsl #2]
+    and     w4, w16, #0xff
+    ldr     s6, [x9, x4, lsl #2]
+    and     w4, w17, #0xff
+    ldr     s7, [x9, x4, lsl #2]
+    mov     v4.s[1], v5.s[0]
+    mov     v4.s[2], v6.s[0]
+    mov     v4.s[3], v7.s[0]
+
+    fadd    v0.4s,  v0.4s,  v4.4s
+    fadd    v16.4s, v16.4s, v0.4s
+
+    add     x1, x1, #0x800
+    subs    x6, x6, #2
+
+.L4_tail_ge1:
+    cbz     x6, .L4_store
+
+    // 1 byte per code
+    ldrb    w14, [x10], #1
+    ldrb    w15, [x11], #1
+    ldrb    w16, [x12], #1
+    ldrb    w17, [x13], #1
+
+    mov     x8, x1
+    ldr     s0, [x8, x14, lsl #2]
+    ldr     s1, [x8, x15, lsl #2]
+    ldr     s2, [x8, x16, lsl #2]
+    ldr     s3, [x8, x17, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    mov     v0.s[2], v2.s[0]
+    mov     v0.s[3], v3.s[0]
+    fadd    v16.4s, v16.4s, v0.4s
+
+.L4_store:
+    str     q16, [x3]
+    ret
+.size DistanceCodesN8x4S, .-DistanceCodesN8x4S
+
+
+// ============================================================
+// DistanceCodesN8x2S
+//   2 codes packed as [code0(M)][code1(M)]
+//   AAPCS64: x0=M, x1=sim_table, x2=codes, x3=result, s0=dis
+// ============================================================
+.global DistanceCodesN8x2S
+.type   DistanceCodesN8x2S, %function
+DistanceCodesN8x2S:
+    dup     v16.2s, v0.s[0]
+
+    // c0, c1
+    mov     x10, x2
+    add     x11, x2, x0
+
+    mov     x6, x0
+    cbz     x6, .L2_store
+
+    cmp     x6, #4
+    b.lt    .L2_tail_ge2
+
+.L2_loop_main:
+    prfm    pldl1keep, [x1, #8192]
+
+    ldr     w12, [x10], #4
+    ldr     w13, [x11], #4
+
+    mov     x8, x1
+    add     x9, x1, #0x400
+    add     x5, x1, #0x800
+    add     x2, x1, #0xC00
+
+    // row0 byte0
+    and     w4, w12, #0xff
+    ldr     s0, [x8, x4, lsl #2]
+    and     w4, w13, #0xff
+    ldr     s1, [x8, x4, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+    // row1 byte1
+    ubfx    w4, w12, #8, #8
+    ldr     s0, [x9, x4, lsl #2]
+    ubfx    w4, w13, #8, #8
+    ldr     s1, [x9, x4, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+    // row2 byte2
+    ubfx    w4, w12, #16, #8
+    ldr     s0, [x5, x4, lsl #2]
+    ubfx    w4, w13, #16, #8
+    ldr     s1, [x5, x4, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+    // row3 byte3
+    lsr     w12, w12, #24
+    lsr     w13, w13, #24
+    ldr     s0, [x2, x12, lsl #2]
+    ldr     s1, [x2, x13, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+    add     x1, x1, #0x1000
+    subs    x6, x6, #4
+    cmp     x6, #4
+    b.ge    .L2_loop_main
+
+.L2_tail_ge2:
+    cmp     x6, #2
+    b.lt    .L2_tail_ge1
+
+    prfm    pldl1keep, [x1, #8192]
+
+    ldrh    w12, [x10], #2
+    ldrh    w13, [x11], #2
+
+    mov     x8, x1
+    add     x9, x1, #0x400
+
+    // row0 byte0
+    and     w4, w12, #0xff
+    ldr     s0, [x8, x4, lsl #2]
+    and     w4, w13, #0xff
+    ldr     s1, [x8, x4, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+    // row1 byte1
+    lsr     w12, w12, #8
+    lsr     w13, w13, #8
+    and     w4, w12, #0xff
+    ldr     s0, [x9, x4, lsl #2]
+    and     w4, w13, #0xff
+    ldr     s1, [x9, x4, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+    add     x1, x1, #0x800
+    subs    x6, x6, #2
+
+.L2_tail_ge1:
+    cbz     x6, .L2_store
+
+    ldrb    w12, [x10]
+    ldrb    w13, [x11]
+
+    mov     x8, x1
+    ldr     s0, [x8, x12, lsl #2]
+    ldr     s1, [x8, x13, lsl #2]
+    mov     v0.s[1], v1.s[0]
+    fadd    v16.2s, v16.2s, v0.2s
+
+.L2_store:
+    str     d16, [x3]
+    ret
+.size DistanceCodesN8x2S, .-DistanceCodesN8x2S
+
+
+// ============================================================
+// DistanceCodesN8x1S
+//   AAPCS64: x0=M, x1=sim_table, x2=code, s0=dis, return s0
+// ============================================================
+.global DistanceCodesN8x1S
+.type   DistanceCodesN8x1S, %function
+DistanceCodesN8x1S:
+    // acc in s16
+    fmov    s16, s0
+
+    mov     x6, x0
+    cbz     x6, .L1_ret
+
+    cmp     x6, #4
+    b.lt    .L1_tail_ge2
+
+.L1_loop_main:
+    prfm    pldl1keep, [x1, #8192]
+
+    ldr     w12, [x2], #4
+
+    mov     x8, x1
+    add     x9, x1, #0x400
+    add     x5, x1, #0x800
+    add     x3, x1, #0xC00
+
+    // row0 byte0
+    and     w4, w12, #0xff
+    ldr     s0, [x8, x4, lsl #2]
+    fadd    s16, s16, s0
+
+    // row1 byte1
+    ubfx    w4, w12, #8, #8
+    ldr     s0, [x9, x4, lsl #2]
+    fadd    s16, s16, s0
+
+    // row2 byte2
+    ubfx    w4, w12, #16, #8
+    ldr     s0, [x5, x4, lsl #2]
+    fadd    s16, s16, s0
+
+    // row3 byte3
+    lsr     w12, w12, #24
+    ldr     s0, [x3, x12, lsl #2]
+    fadd    s16, s16, s0
+
+    add     x1, x1, #0x1000
+    subs    x6, x6, #4
+    cmp     x6, #4
+    b.ge    .L1_loop_main
+
+.L1_tail_ge2:
+    cmp     x6, #2
+    b.lt    .L1_tail_ge1
+
+    prfm    pldl1keep, [x1, #8192]
+
+    ldrh    w12, [x2], #2
+
+    mov     x8, x1
+    add     x9, x1, #0x400
+
+    // row0 byte0
+    and     w4, w12, #0xff
+    ldr     s0, [x8, x4, lsl #2]
+    fadd    s16, s16, s0
+
+    // row1 byte1
+    lsr     w12, w12, #8
+    and     w4, w12, #0xff
+    ldr     s0, [x9, x4, lsl #2]
+    fadd    s16, s16, s0
+
+    add     x1, x1, #0x800
+    subs    x6, x6, #2
+
+.L1_tail_ge1:
+    cbz     x6, .L1_ret
+
+    ldrb    w12, [x2]
+    ldr     s0, [x1, x12, lsl #2]
+    fadd    s16, s16, s0
+
+.L1_ret:
+    fmov    s0, s16
+    ret
+.size DistanceCodesN8x1S, .-DistanceCodesN8x1S
