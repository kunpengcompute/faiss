+            neon_query = vld1q_f16(x + i);
+            neon_base1 = vld1q_f16(y + i);
+            neon_base2 = vld1q_f16(y + d + i);
+            neon_base3 = vld1q_f16(y + 2 * d + i);
+            neon_base4 = vld1q_f16(y + 3 * d + i);
