+    neon_base3 = vld1q_f32(y + 40);
+    neon_base4 = vld1q_f32(y + 44);
+    neon_base5 = vld1q_f32(y + 48);
+    neon_base6 = vld1q_f32(y + 52);
+    neon_base7 = vld1q_f32(y + 56);
