+            TBL2_LOOKUP_ASM(res1, dictCombine, mask1_1);
+            TBL2_LOOKUP_ASM(res0_2, dictCombine, mask0_2);
+            TBL2_LOOKUP_ASM(res1_2, dictCombine, mask1_2);
