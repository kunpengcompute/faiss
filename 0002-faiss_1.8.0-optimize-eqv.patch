+    float32x4_t res1 = vdupq_n_f32(0.0f);
+    float32x4_t res2 = vdupq_n_f32(0.0f);
+    float32x4_t res3 = vdupq_n_f32(0.0f);
+    float32x4_t res4 = vdupq_n_f32(0.0f);
