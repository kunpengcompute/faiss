+            double sgemv_time = sgemv_func_test<true>(sgemv_test, y, x, square_y, d, ny, nx, nloops);
+            print_result_table(verbose, "L2_sgemv", sgemv_time, L2_fops, nx * ny, sgemv_test, gt, 1e-4);
