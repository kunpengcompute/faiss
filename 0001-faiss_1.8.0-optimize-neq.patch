+        res1 = vdotq_u32(res1, d8_0, d8_0);
+        res2 = vdotq_u32(res2, d8_1, d8_1);
+        res3 = vdotq_u32(res3, d8_2, d8_2);
+        res4 = vdotq_u32(res4, d8_3, d8_3);
