+        d0_0 = vpaddq_f16(d0_0, d1_0);
+        /* 4 -> 2 */
+        d0_0 = vpaddq_f16(d0_0, d0_0);
+        /* 2 -> 1 */
+        d0_0 = vpaddq_f16(d0_0, d0_0);
