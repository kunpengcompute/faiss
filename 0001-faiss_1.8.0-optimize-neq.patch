+
+        neon_base1 = vld1q_f32(y + 64 * i + 32);
+        neon_base2 = vld1q_f32(y + 64 * i + 36);
+        neon_base3 = vld1q_f32(y + 64 * i + 40);
+        neon_base4 = vld1q_f32(y + 64 * i + 44);
+        neon_base5 = vld1q_f32(y + 64 * i + 48);
+        neon_base6 = vld1q_f32(y + 64 * i + 52);
