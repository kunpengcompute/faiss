+
+        neon_res1 = vfmaq_f16(neon_res1, neon_query, neon_base1);
+        neon_res2 = vfmaq_f16(neon_res2, neon_query, neon_base2);
+        neon_res3 = vfmaq_f16(neon_res3, neon_query, neon_base3);
