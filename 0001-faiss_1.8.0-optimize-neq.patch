+        for (i = single_round; i <= d - single_round; i += single_round) {
+            x_0 = vld1q_f16(x + i);
+            y0_0 = vld1q_f16(y0 + i);
+            y1_0 = vld1q_f16(y1 + i);
+            const float16x8_t q0_0 = vsubq_f16(x_0, y0_0);
+            const float16x8_t q1_0 = vsubq_f16(x_0, y1_0);
