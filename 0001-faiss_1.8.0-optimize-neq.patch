+            prefetch_Lx(y[1] + i + multi_round);
+            prefetch_Lx(y[2] + i + multi_round);
+            prefetch_Lx(y[3] + i + multi_round);
+            prefetch_Lx(y[4] + i + multi_round);
+            prefetch_Lx(y[5] + i + multi_round);
+            prefetch_Lx(y[6] + i + multi_round);
