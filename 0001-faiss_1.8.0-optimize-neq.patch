+    std::vector<faiss::HNSW::storage_idx_t> nearest_fp16(nq * nprobe);
+    for (int i = 0; i < nq; i++) {
+        for (int j = 0; j < nprobe; j++) {
+            nearest_fp16[i * nprobe + j] = init_labels_fp16[i * nprobe + j];
