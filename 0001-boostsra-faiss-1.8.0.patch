+    }
+    if (ny & 4) {
+        krl_L2sqr_batch4_u8u32(x, y + i * d, d, dis + i);
+        i += 4;
+    }
+    if (ny & 2) {
+        krl_L2sqr_batch2_u8u32(x, y + i * d, d, dis + i);
+        i += 2;
+    }
+    if (ny & 1) {
+        krl_L2sqr_u8u32(x, y + i * d, d, &dis[i], 1);
