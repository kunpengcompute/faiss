+        float16x8_t x_0 = vld1q_f16(x);
+        float16x8_t x_1 = vld1q_f16(x + 8);
+
+        float16x8_t y0_0 = vld1q_f16(y);
+        float16x8_t y0_1 = vld1q_f16(y + 8);
+        float16x8_t y1_0 = vld1q_f16(y + d);
+        float16x8_t y1_1 = vld1q_f16(y + d + 8);
