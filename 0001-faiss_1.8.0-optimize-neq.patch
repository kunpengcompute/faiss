+            d12 += x[i] * *(y[12] + i);
+            d13 += x[i] * *(y[13] + i);
+            d14 += x[i] * *(y[14] + i);
+            d15 += x[i] * *(y[15] + i);
+        }
+        dis[0] += d0;
+        dis[1] += d1;
+        dis[2] += d2;
+        dis[3] += d3;
+        dis[4] += d4;
+        dis[5] += d5;
+        dis[6] += d6;
